{
  "name": "FanShim Controller",
  "version": "1.0.13",
  "slug": "fanshim",
  "description": "Controla ventoinha FanShim com base na temperatura da CPU",
  "startup": "services",
  "boot": "auto",
  "arch": [
    "aarch64",
    "armv7",
    "armhf"
  ],
  "devices": [
    "/dev/gpiomem",
    "/dev/gpiochip0"
  ],
  "options": {
    "on_temperature": 60,
    "off_temperature": 50,
    "check_interval": 5
  },
  "schema": {
    "on_temperature": "int",
    "off_temperature": "int",
    "check_interval": "int"
  },
  "privileged": [
    "SYS_ADMIN",
    "SYS_RAWIO"
  ]
}